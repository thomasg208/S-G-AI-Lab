rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------
    // ADMINS COLLECTION - FIXED
    // -----------------------------------------
    match /admins/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email_verified == true
                         && request.auth.token.email.matches('.*@sgagilab.com|@gmail.com');
    }

    // -----------------------------------------
    // LEADS COLLECTION - FIXED
    // -----------------------------------------
    match /leads/{leadId} {
      // Public can submit leads
      allow create: if true;

      // Only admins can read/update/delete
      allow read, update, delete: if request.auth != null
                                  && request.auth.token.email_verified == true
                                  && request.auth.token.email.matches('.*@sgagilab.com|@gmail.com');
    }

    // -----------------------------------------
    // SETTINGS COLLECTION - ADDED
    // -----------------------------------------
    match /settings/{settingId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email_verified == true
                         && request.auth.token.email.matches('.*@sgagilab.com|@gmail.com');
    }

    // -----------------------------------------
    // NOTIFICATIONS COLLECTION - ADDED
    // -----------------------------------------
    match /notifications/{notificationId} {
      allow create: if true; // System can create notifications
      allow read, delete: if request.auth != null
                          && request.auth.token.email_verified == true
                          && request.auth.token.email.matches('.*@sgagilab.com|@gmail.com');
    }

    // -----------------------------------------
    // DENY EVERYTHING ELSE
    // -----------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
